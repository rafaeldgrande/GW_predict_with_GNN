verbosity 3
use_wfn_hdf5
degeneracy_check_override
cell_slab_truncation
dont_use_vxcdat
screening_semiconductor
no_symmetries_q_grid

! Compute QP corrections for bands 9-20 (valence + first conduction bands)
band_index_min 9
band_index_max 20

! Full 6x6x1 k-point grid (36 points, no symmetry reduction)
begin kpoints
