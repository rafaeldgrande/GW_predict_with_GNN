&control
    calculation  = 'scf'
    prefix       = 'mos2'
    outdir       = './tmp'
    pseudo_dir   = './pseudos'
    wf_collect   = .true.
/
&system
    ibrav        = 4
    a            = 3.1604
    c            = 25.0
    nat          = 3
    ntyp         = 2
    ecutwfc      = 60.0
    ecutrho      = 240.0
    occupations  = 'smearing'
    smearing     = 'mp'
    degauss      = 0.005
/
&electrons
    conv_thr     = 1.0e-10
    mixing_beta  = 0.7
/
ATOMIC_SPECIES
  Mo  95.96  Mo.upf
  S   32.06  S.upf

ATOMIC_POSITIONS {angstrom}
  Mo   0.000000   0.000000   0.000000
  S    1.580200   0.912333   1.563408
  S    1.580200   0.912333  -1.563408

K_POINTS {automatic}
  12 12 1  0 0 0
