&CONTROL
   calculation      = 'bands'
   verbosity        = 'high'
   tstress          = .true.
   tprnfor          = .true.
   outdir           = './'
   prefix           = 'mos2'
   pseudo_dir       = './pseudos/nc-sr-04_pw_standard/'
/
&SYSTEM
   nbnd             = 30
   ecutwfc          = 35
   occupations      = 'smearing'
   degauss          = 0.01
   smearing         = 'gaussian'
   ntyp             = 2
   nat              = 3
   ibrav            = 0
/
&ELECTRONS
   conv_thr         = 1e-08
   diagonalization  = 'david'
   diago_david_ndim = 4
   diago_full_acc   = .true.
/

ATOMIC_SPECIES
Mo 95.95 Mo.upf
S  32.06 S.upf

